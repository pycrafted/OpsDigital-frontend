<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Désactiver le default document pour que IIS ne serve pas index.html directement -->
    <defaultDocument enabled="false" />

    <handlers>
      <!-- Toutes les requêtes → server.js via iisnode (Express gère le statique + SPA) -->
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <httpErrors errorMode="Detailed" />

  </system.webServer>
</configuration>
